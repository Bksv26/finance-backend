# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────────
# Change this to a long random string in any non-local environment
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=finance_dev_secret_change_in_prod

# Token lifetime (e.g. 8h, 1d, 30m)
JWT_EXPIRES_IN=8h

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite file. Defaults to finance.db in the project root.
DB_PATH=./finance.db

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX=100
# Window size in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in dev)
# Example: CORS_ORIGINS=http://localhost:5173,https://your-dashboard.com
CORS_ORIGINS=

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
